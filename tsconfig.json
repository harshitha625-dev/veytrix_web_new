{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "lib": [
      "es2020",
      "dom",
      "dom.iterable"
    ],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": [
        "Frontend/src/*"
      ]
    }
  },
  "include": [
    "Frontend/src/**/*",
    "Frontend/main.tsx",
    "Frontend/vite.config.ts",
    "vite.config.ts",
    "Backend/supabase.js"
  ]
}